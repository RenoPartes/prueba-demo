# Variables del Copiloto de Datos del Negocio.
# Copia este archivo a .env.local y completa los valores reales.
# .env.local esta gitignored: NUNCA se versiona y NUNCA se ponen secretos en codigo.

# --- Oracle (solo lectura) ---
# Usuario y password de una credencial Oracle con privilegios de LECTURA
# sobre las tablas de negocio y las vistas del diccionario (ALL_TABLES, etc.).
DB_USER=renopartes_dev
DB_PASSWORD=<password-oracle>
# Cadena de conexion: host:puerto/servicio  (ej. 10.30.1.201:1521/ORCLPDB1)
DB_CONNECT_STRING=10.30.1.201:1521/<servicio>
# Opcional: owner/schema de las tablas de negocio. Si se omite, se descubre
# automaticamente a partir del usuario de conexion.
DB_SCHEMA=
# Opcional: modo Thick para servidores Oracle antiguos (< 12.1, p. ej. 11g).
# Ruta al directorio de Oracle Instant Client (misma arquitectura que Node).
# En macOS Apple Silicon, el Instant Client NATIVO ARM64 (23.x) conecta a 11g
# sin Docker ni Rosetta — ver README. Vacio = modo Thin (requiere Oracle >= 12.1).
ORACLE_CLIENT_LIB_DIR=
# Opcional: carpeta con sqlnet.ora (solo si el 11g da ORA-28040; usar
# SQLNET.ALLOWED_LOGON_VERSION_CLIENT=11).
ORACLE_CLIENT_CONFIG_DIR=

# --- OpenAI ---
OPENAI_API_KEY=<openai-api-key>
# Modelo a usar. gpt-5.5 por defecto; cambialo aqui si tu cuenta usa otro id.
OPENAI_MODEL=gpt-5.5
